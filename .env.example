
# --- Required settings even when working locally. ---

# OpenAI-compatible LLM config
# By default this project is set up to run FOR FREE using an OpenAI-compatible
# provider instead of paid OpenAI/AWS SageMaker. Recommended free options:
#
#  1) Groq (fast, generous free tier, no local GPU needed):
#     OPENAI_MODEL_ID=llama-3.1-8b-instant
#     OPENAI_API_KEY=<your free Groq API key from https://console.groq.com>
#     OPENAI_BASE_URL=https://api.groq.com/openai/v1
#
#  2) Local Ollama (fully offline, no API key/costs, needs `ollama pull llama3.1`):
#     OPENAI_MODEL_ID=llama3.1
#     OPENAI_API_KEY=ollama
#     OPENAI_BASE_URL=http://localhost:11434/v1
#
# Leave OPENAI_BASE_URL empty to use the real OpenAI API instead (paid).
OPENAI_MODEL_ID=llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Huggingface API config (free - just create an account and generate a token)
HUGGINGFACE_ACCESS_TOKEN=

# Comet ML (during training and inference) - free tier, no credit card required
COMET_API_KEY=
COMET_WORKSPACE=  # such as your Comet username

# Set to false only if you have deployed your own fine-tuned model to a real
# (paid) AWS SageMaker endpoint and want inference to use that instead of the
# free OpenAI-compatible provider above.
USE_FREE_LLM_FOR_GENERATION=true

# --- Required settings ONLY when using Qdrant Cloud and AWS SageMaker ---
# These are optional. Leave USE_QDRANT_CLOUD=false to use the free local
# Qdrant container started by docker-compose instead.

# Qdrant cloud vector database connection config
USE_QDRANT_CLOUD=false
QDRANT_CLOUD_URL=
QDRANT_APIKEY=

# AWS authentication config (only needed if you fine-tune/deploy on SageMaker)
AWS_ARN_ROLE=
AWS_REGION=eu-central-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
